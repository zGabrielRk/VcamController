<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- no-sandbox: acesso ao filesystem fora do container (necessário para /var/jb/) -->
	<key>com.apple.private.security.no-sandbox</key>
	<true/>
	<!-- no-container e platform-application removidos: causam crash no launch -->
</dict>
</plist>
